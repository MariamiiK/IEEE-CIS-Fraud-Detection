tratify=y_all)\n\nselector  = SelectKBest(f_classif, k=50)\nX_sel     = selector.fit_transform(X_s, y_s)\nsel_cols  = train.columns[selector.get_support()].tolist()\n\nX_full_sel = train[sel_cols].values\ntest_sel   = test[sel_cols].values\n\nprint(f\"Sample size  : {X_s.shape[0]:,} rows  ({y_s.mean():.4f} fraud rate)\")\nprint(f\"Features     : {len(sel_cols)}\")\n\nscaler = StandardScaler()\nX_sc   = scaler.fit_transform(X_sel)\nX_tr, X_v, y_tr, y_v = train_test_split(\n    X_sc, y_s, test_size=0.2,\n    random_state=42, stratify=y_s)\n\nprint(f\"Train : {X_tr.shape[0]:,}  Val : {X_v.shape[0]:,}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-07T11:07:09.892597Z","iopub.execute_input":"2026-05-07T11:07:09.893044Z","iopub.status.idle":"2026-05-07T11:08:00.583475Z","shell.execute_reply.started":"2026-05-07T11:07:09.893019Z","shell.execute_reply":"2026-05-07T11:08:00.582456Z"}},"outputs":[{"name":"stdout","text":"Sample size  : 177,162 rows  (0.0350 fraud rate)\nFeatures     : 50\nTrain : 141,729  Val : 35,433\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"# Feature Engineering","metadata":{}},{"cell_type":"code","source":"mlflow.end_run()\n \nC_values = [0.001, 0.01, 0.1, 1.0, 10.0]\nC_results = []\n \nfor C in C_values:\n    with mlflow.start_run(run_name=f\"LR_C_{C}\"):\n \n        model = LogisticRegression(\n            C=C, penalty='l2',\n            solver='lbfgs',         \n            class_weight='balanced',\n            max_iter=200, tol=1e-3,\n            random_state=42,\n        )\n        t0 = time.time()\n        model.fit(X_tr, y_tr)\n        elapsed = time.time() - t0\n \n        train_auc = roc_auc_score(y_tr, model.predict_proba(X_tr)[:, 1])\n        val_auc   = roc_auc_score(y_v,  model.predict_proba(X_v)[:, 1])\n        gap       = round(train_auc - val_auc, 4)\n \n        mlflow.log_params({\n            \"C\": C, \"penalty\": \"l2\", \"solver\": \"lbfgs\",\n            \"class_weight