_strategy='median'):\n \n    df = df.copy()\n \n    num_cols = df.select_dtypes(include=[np.number]).columns\n    cat_cols = df.select_dtypes(include=['object']).columns\n \n    for col in num_cols:\n        if df[col].isnull().any():\n            fill = df[col].median() if num_strategy == 'median' else df[col].mean()\n            df[col] = df[col].fillna(fill)\n \n    for col in cat_cols:\n        df[col] = df[col].fillna('unknown')\n        le = LabelEncoder()\n        df[col] = le.fit_transform(df[col].astype(str))\n \n    return df\n \n \ndef drop_high_missing(df_train, df_test, threshold=0.9):\n   \n    missing_pct = df_train.isnull().mean()\n    drop_cols = missing_pct[missing_pct > threshold].index.tolist()\n    print(f\"  Dropping {len(drop_cols)} cols with >{threshold*100:.0f}% missing in train\")\n    df_train = df_train.drop(columns=drop_cols, errors='ignore')\n    df_test  = df_test.drop(columns=drop_cols, errors='ignore')\n    return df_train, df_test, drop_cols","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-07T04:44:05.321407Z","iopub.execute_input":"2026-05-07T04:44:05.322425Z","iopub.status.idle":"2026-05-07T04:44:06.896873Z","shell.execute_reply.started":"2026-05-07T04:44:05.322394Z","shell.execute_reply":"2026-05-07T04:44:06.895791Z"}},"outputs":[],"execution_count":27},{"cell_type":"code","source":"MODEL_NAME = \"DecisionTree\" \n \nmlflow.set_experiment(f\"DecisionTree_Training\")  \n \nwith mlflow.start_run(run_name=f\"DecisionTree_Cleaning\"):\n \n   \n    train_fe = feature_engineering(train)\n    test_fe  = feature_engineering(test)\n \n    \n    test_ids = test_fe['TransactionID'].copy()\n    train_fe = train_fe.drop(columns=['TransactionID'])\n    test_fe  = test_fe.drop(columns=['TransactionID'])\n    y        = train_fe.pop('isFraud')\n \n    \n    train_fe, test_fe, dropped_cols = drop_high_missing(train_fe, test_fe, threshold=0.9)\n \n   \n    train_fe = encode_and_fill(train_fe, num_strategy='median')\n    test_f