    " \n",
    "def drop_high_missing(df_train, df_test, threshold=0.9):\n",
    "    \"\"\"\n",
    "    Drop columns that are >threshold missing in the train set.\n",
    "    Applies the same drop list to test for consistency.\n",
    "    \"\"\"\n",
    "    missing_pct = df_train.isnull().mean()\n",
    "    drop_cols = missing_pct[missing_pct > threshold].index.tolist()\n",
    "    print(f\"  Dropping {len(drop_cols)} cols with >{threshold*100:.0f}% missing in train\")\n",
    "    df_train = df_train.drop(columns=drop_cols, errors='ignore')\n",
    "    df_test  = df_test.drop(columns=drop_cols, errors='ignore')\n",
    "    return df_train, df_test, drop_cols"
   ]
