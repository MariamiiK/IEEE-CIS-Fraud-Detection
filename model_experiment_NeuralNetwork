    "class FraudNet(nn.Module):\n",
    "    def __init__(self, n_features, hidden_sizes, dropout=0.3, use_bn=True):\n",
    "        super().__init__()\n",
    "        layers = []\n",
    "        in_dim = n_features\n",
    "        for h in hidden_sizes:\n",
    "            layers.append(nn.Linear(in_dim, h))\n",
    "            if use_bn:\n",
    "                layers.append(nn.BatchNorm1d(h))\n",
    "            layers.append(nn.ReLU())\n",
    "            layers.append(nn.Dropout(dropout))\n",
    "            in_dim = h\n",
    "        layers.append(nn.Linear(in_dim, 1))\n",
    "        self.net = nn.Sequential(*layers)\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n",
    "\n",
    "\n",
    "def train_nn(hidden_sizes, dropout, lr, epochs, batch_size=4096,\n",
    "             weight_decay=1e-4, patience=5, verbose=True):\n",
    "    tr_loader, va_loader = make_loaders(\n",
    "        X_train_sc, y_train, X_val_sc, y_val, batch_size)\n",
    "\n",
    "    model     = FraudNet(N_FEATURES, hidden_sizes, dropout).to(DEVICE)\n",
    "    criterion = nn.BCEWithLogitsLoss(pos_weight=POS_WEIGHT)\n",
    "    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)\n",
    "    scheduler = optim.lr_scheduler.ReduceLROnPlateau(\n",
    "        optimizer, mode='max', factor=0.5, patience=2)\n",
    "\n",
    "    best_val_auc, best_state, no_improve = 0.0, None, 0\n",
    "    history = []\n",
    "\n",
    "    for epoch in range(1, epochs + 1):\n",
    "        model.train()\n",
    "        for Xb, yb in tr_loader:\n",
    "            Xb, yb = Xb.to(DEVICE), yb.to(DEVICE)\n",
    "            optimizer.zero_grad()\n",
    "            loss = criterion(model(Xb).squeeze(), yb)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "\n",
    "        tr_auc  = eval_auc(model, X_train_sc, y_train)\n",
    "        val_auc = eval_auc(model, X_val_sc,   y_val)\n",
    "        scheduler.step(val_auc)\n",
    "        history.append({'epoch': epoch, 'train_auc': tr_auc, 'val_auc': val_auc})\n",
    "\n",
    "        if val_auc > best_val_auc:\n",
    "            best_val_auc = val_auc\n",
    "            best_state   = {k: v.cpu().clone() for k, v in model.state_dict().items()}\n",
    "            no_improve   = 0\n",
    "        else:\n",
    "            no_improve += 1\n",
    "\n",
    "        if verbose and (epoch % 5 == 0 or epoch == 1):\n",
    "            print(f\"  Epoch {epoch:>3}  Train: {tr_auc}  Val: {val_auc}\")\n",
    "\n",
    "        if no_improve >= patience:\n",
    "            if verbose:\n",
    "                print(f\"  Early stop at epoch {epoch}\")\n",
    "            break\n",
    "\n",
    "    model.load_state_dict(best_state)\n",
    "    return model, best_val_auc, history\n",
    "\n",
    "print(\"FraudNet architecture ready\")\n",
    "print(FraudNet(N_FEATURES, [256, 128, 64]))"
   ]
