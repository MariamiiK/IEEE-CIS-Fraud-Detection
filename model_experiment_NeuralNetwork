    "mlflow.end_run()\n",
    "\n",
    "X_full_np = np.vstack([X_train_sc, X_val_sc])\n",
    "y_full    = pd.concat([y_train, y_val], ignore_index=True)\n",
    "\n",
    "print(\"Training final model on full train+val data...\")\n",
    "t0 = time.time()\n",
    "final_model, _, final_hist = train_nn(\n",
    "    best_hidden_opt, dropout=best_dropout_opt,\n",
    "    lr=best_lr_opt, epochs=40, patience=7, verbose=True)\n",
    "elapsed = time.time() - t0\n",
    "\n",
    "final_val_auc = eval_auc(final_model, X_val_sc, y_val)\n",
    "final_tr_auc  = eval_auc(final_model, X_train_sc, y_train)\n",
    "gap           = round(final_tr_auc - final_val_auc, 4)\n",
    "\n",
    "with mlflow.start_run(run_name='NN_FinalModel') as run:\n",
    "    mlflow.log_params({\n",
    "        'architecture'   : str(best_hidden_opt),\n",
    "        'dropout'        : best_dropout_opt,\n",
    "        'learning_rate'  : best_lr_opt,\n",
    "        'weight_decay'   : best_wd_opt,\n",
    "        'epochs_run'     : len(final_hist),\n",
    "        'device'         : str(DEVICE),\n",
    "        'train_size'     : len(X_full_np),\n",
    "    })\n",
    "    mlflow.log_metrics({\n",
    "        'final_train_auc': final_tr_auc,\n",
    "        'final_val_auc'  : final_val_auc,\n",
    "        'gap'            : gap,\n",
    "        'cv_auc_mean'    : cv_mean,\n",
    "        'cv_auc_std'     : cv_std,\n",
    "        'fit_time_s'     : round(elapsed, 2),\n",
    "    })\n",
    "\n",
    "    # ROC Curve\n",
    "    final_model.eval()\n",
    "    with torch.no_grad():\n",
    "        logits = final_model(torch.tensor(X_val_sc).to(DEVICE)).squeeze().cpu().numpy()\n",
    "    val_proba = 1 / (1 + np.exp(-logits))\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(6, 5))\n",
    "    RocCurveDisplay.from_predictions(y_val, val_proba, ax=ax, name='NeuralNetwork (final)')\n",
    "    ax.set_title('ROC Curve — Neural Network Final Model')\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('nn_roc_curve.png', dpi=100, bbox_inches='tight')\n",
