auc(model, X_train_sc, y_train)\n        val_auc = eval_auc(model, X_val_sc,   y_val)\n        scheduler.step(val_auc)\n        history.append({'epoch': epoch, 'train_auc': tr_auc, 'val_auc': val_auc})\n\n        if val_auc > best_val_auc:\n            best_val_auc = val_auc\n            best_state   = {k: v.cpu().clone() for k, v in model.state_dict().items()}\n            no_improve   = 0\n        else:\n            no_improve += 1\n\n        if verbose and (epoch % 5 == 0 or epoch == 1):\n            print(f\"  Epoch {epoch:>3}  Train: {tr_auc}  Val: {val_auc}\")\n\n        if no_improve >= patience:\n            if verbose:\n                print(f\"  Early stop at epoch {epoch}\")\n            break\n\n    model.load_state_dict(best_state)\n    return model, best_val_auc, history\n\nprint(\"FraudNet architecture ready\")\nprint(FraudNet(N_FEATURES, [256, 128, 64]))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-07T17:22:05.337466Z","iopub.execute_input":"2026-05-07T17:22:05.338301Z","iopub.status.idle":"2026-05-07T17:22:05.387545Z","shell.execute_reply.started":"2026-05-07T17:22:05.338269Z","shell.execute_reply":"2026-05-07T17:22:05.386751Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"mlflow.end_run()\n\nprint(\"Training Baseline NN  [256 → 128 → 64, dropout=0.3, lr=1e-3]\")\nt0 = time.time()\nbaseline_model, baseline_auc, baseline_hist = train_nn(\n    hidden_sizes=[256, 128, 64],\n    dropout=0.3,\n    lr=1e-3,\n    epochs=30,\n    patience=5,\n)\nelapsed = time.time() - t0\n\ntrain_auc = eval_auc(baseline_model, X_train_sc, y_train)\ngap       = round(train_auc - baseline_auc, 4)\n\nwith mlflow.start_run(run_name='NN_Baseline'):\n    mlflow.log_params({\n        'architecture'  : '256-128-64',\n        'dropout'       : 0.3,\n        'learning_rate' : 1e-3,\n        'batch_size'    : 4096,\n        'epochs_run'    : len(baseline_hist),\n        'device'        : str(DEVICE),\n    })\n    mlflow.log_metrics({\n 