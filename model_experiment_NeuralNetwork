    "def reduce_mem_usage(df):\n",
    "    \"\"\"Downcast numerics to save RAM — critical for 1.35 GB dataset.\"\"\"\n",
    "    for col in df.select_dtypes(include=['int']).columns:\n",
    "        df[col] = pd.to_numeric(df[col], downcast='integer')\n",
    "    for col in df.select_dtypes(include=['float']).columns:\n",
    "        df[col] = pd.to_numeric(df[col], downcast='float')\n",
    "    return df\n",
    " \n",
    " \n",
    "def feature_engineering(df):\n",
    "    \"\"\"\n",
    "    Time-based, amount-based, and domain features.\n",
    "    Applied identically to train and test.\n",
    "    \"\"\"\n",
    "    df = df.copy()\n",
    " \n",
    "    df['tx_hour']    = (df['TransactionDT'] // 3600) % 24         # hour of day\n",
    "    df['tx_dayofwk'] = (df['TransactionDT'] // 86400) % 7         # day of week\n",
    "    df['tx_week']    = (df['TransactionDT'] // 604800)             # week index\n",
    "    df['tx_month']   = (df['TransactionDT'] // (86400 * 30)) % 12\n",
    " \n",
    "    df['is_night'] = ((df['tx_hour'] >= 0) & (df['tx_hour'] < 6)).astype(np.int8)\n",
    " \n",
    "    df['TransactionAmt_log'] = np.log1p(df['TransactionAmt'])\n",
    " \n",
    "    card_mean = df.groupby('card1')['TransactionAmt'].transform('mean')\n",
    "    card_std  = df.groupby('card1')['TransactionAmt'].transform('std').fillna(1).replace(0, 1)\n",
    "    df['TransactionAmt_card1_z'] = (df['TransactionAmt'] - card_mean) / card_std\n",
    " \n",
    "    df['is_round_amount'] = (df['TransactionAmt'] % 1 == 0).astype(np.int8)\n",
    " \n",
    "    df['P_email_tld'] = df['P_emaildomain'].fillna('unknown').apply(\n",
    "        lambda x: x.split('.')[-1] if '.' in str(x) else 'unknown')\n",
    "    df['R_email_tld'] = df['R_emaildomain'].fillna('unknown').apply(\n",
    "        lambda x: x.split('.')[-1] if '.' in str(x) else 'unknown')\n",
    " \n",
    "    df['same_email_domain'] = (df['P_emaildomain'] == df['R_emaildomain']).astype(np.int8)\n",
    " \n",
    "\n",
    "    df['card1_addr1'] = (df['card1'].astype(str) + '_' +\n",
    "                         df['addr1'].astype(str))\n",
    " \n",
    "    return df\n",
    " \n",
    " \n",
    "def encode_and_fill(df, num_strategy='median'):\n",
    "    \"\"\"\n",
    "    1. Fill numeric NaNs with median (or mean).\n",
    "    2. Fill categorical NaNs with 'unknown'.\n",
    "    3. Label-encode all object columns.\n",
    "    Returns the processed DataFrame.\n",
    "    \"\"\"\n",
    "    df = df.copy()\n",
    " \n",
    "    num_cols = df.select_dtypes(include=[np.number]).columns\n",
    "    cat_cols = df.select_dtypes(include=['object']).columns\n",
    " \n",
    "    for col in num_cols:\n",
    "        if df[col].isnull().any():\n",
    "            fill = df[col].median() if num_strategy == 'median' else df[col].mean()\n",
    "            df[col] = df[col].fillna(fill)\n",
    " \n",
    "    for col in cat_cols:\n",
    "        df[col] = df[col].fillna('unknown')\n",
    "        le = LabelEncoder()\n",
    "        df[col] = le.fit_transform(df[col].astype(str))\n",
    " \n",
    "    return df\n",
